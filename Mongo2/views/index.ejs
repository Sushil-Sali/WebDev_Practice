<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="./style.css">
    <title>Document</title>
</head>
<body>
    
    <h1>All Chats</h1>
    <br>
    <form method="get" action="chats/new">
        <button>New Chat</button>
    </form>
  <%  for(let chat of chats){%>  
   <div class="chat">

    <p>From :<%= chat.from %></p>
    <div class="msg"> <p><%= chat.msg %> </p>
    <form method="get" action="/chats/<%= chat._id %>/edit"><button>Edit</button></form>
    <form method="post" action="/chats/<%= chat._id %>?_method=DELETE"><button>Delete</button></form>
    </div>
    <p>To :<%= chat.to %></p>
    <hr>
    <p><%= chat.createdate.toString().split(" ")[4] %></p>
    <p><%= chat.createdate.toString().split(" ").slice(0,4).join(" ") %></p>
   </div> 
<% } %>

</body>
</html>
